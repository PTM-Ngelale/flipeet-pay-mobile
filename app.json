{
  "expo": {
    "name": "flipeet-pay",
    "slug": "flipeet-pay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/flipeet-logo.png",
    "backgroundColor": "#121212",
    "splash": {
      "image": "./assets/images/flipeet-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "scheme": "flipeetpay",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flipeet.pay",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.flipeet.pay",
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/flipeet-logo.png",
          "color": "#0A66D3",
          "defaultChannel": "default"
        }
      ],
      "./plugins/withGoogleSignIn.js",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Lato-Regular.ttf"
          ]
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ffbf714e-1d6c-4ffe-be48-6c60fe911003"
      }
    },
    "owner": "flipeet-pay",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ffbf714e-1d6c-4ffe-be48-6c60fe911003"
    }
  }
}
